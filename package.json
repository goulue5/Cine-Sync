{
  "name": "cine-sync",
  "version": "0.1.0",
  "description": "Desktop video player with Watch Together",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "build:native": "node-gyp rebuild --runtime=electron --target=$(node -e \"console.log(require('electron/package.json').version)\") --arch=$(node -e \"console.log(process.arch)\") --dist-url=https://electronjs.org/headers",
    "rebuild": "npx @electron/rebuild",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "node-gyp": "^12.2.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.cinesync.app",
    "productName": "Cine-Sync",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mkv",
          "mp4",
          "avi",
          "mov",
          "wmv",
          "flv",
          "webm",
          "m4v",
          "ts",
          "m2ts",
          "mts",
          "mpg",
          "mpeg",
          "ogv"
        ],
        "name": "Video File",
        "description": "Video file playable by Cine-Sync",
        "mimeType": "video/*",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Cine-Sync"
    },
    "portable": {
      "artifactName": "CineSync-portable-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.video"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
